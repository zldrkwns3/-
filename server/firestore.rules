rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Authentication Helper
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // System Bot Asset History
    match /bot_history/{dateId} {
      function isValidSnapshot(data) {
        return data.date is string 
          && data.totalEquity is number 
          && data.operationPool is number 
          && data.safeVault is number;
      }

      allow read: if true; 
      allow create, update: if isValidSnapshot(request.resource.data);
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.email is string && data.email.size() < 256
          && data.balance is number && data.balance >= 0;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && isValidUser(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'displayName']);

      // Portfolio Rules
      match /portfolio/{symbol} {
        function isValidPortfolioItem(data) {
          return data.symbol is string && data.symbol.size() <= 16
            && data.quantity is number && data.quantity >= 0
            && data.averageBuyPrice is number && data.averageBuyPrice >= 0;
        }

        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidPortfolioItem(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Trade Rules
      match /trades/{tradeId} {
        function isValidTrade(data) {
          return data.symbol is string && data.symbol.size() <= 16
            && data.type in ['BUY', 'SELL']
            && data.quantity is number && data.quantity > 0
            && data.price is number && data.price > 0
            && data.timestamp == request.time;
        }

        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTrade(request.resource.data);
      }
    }
  }
}
